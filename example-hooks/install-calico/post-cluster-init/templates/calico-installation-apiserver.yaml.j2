apiVersion: operator.tigera.io/v1
kind: Installation
metadata:
  name: default
spec:
  calicoNetwork:
    bgp: Disabled
    ipPools:
    - cidr: {{ kubernetes_pod_subnet }}
      encapsulation: VXLAN
  serviceCIDRs:
  - {{ kubernetes_service_subnet }}
---
apiVersion: operator.tigera.io/v1
kind: APIServer
metadata:
  name: default
spec: {}
